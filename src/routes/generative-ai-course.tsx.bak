      <AnimatePresence>
        {isModalOpen && (
            <div className="fixed inset-0 z-[100] flex items-center justify-center p-6 bg-midnight/80 backdrop-blur-xl">
                <motion.div initial={{ opacity: 0, scale: 0.9, y: 20 }} animate={{ opacity: 1, scale: 1, y: 0 }} exit={{ opacity: 0, scale: 0.9, y: 20 }} className="relative w-full max-w-md glass p-12 rounded-[3.5rem] border border-gold/30 shadow-[0_0_100px_rgba(251,191,36,0.2)]">
                    <button onClick={() => setIsModalOpen(false)} className="absolute top-8 right-8 text-slate-500 hover:text-gold transition-colors"><X className="w-8 h-8" /></button>
                    <div className="w-20 h-20 rounded-[2.5rem] bg-gold/10 border border-gold/20 flex items-center justify-center text-gold mb-10"><FileText className="w-10 h-10" /></div>
                    <h3 className="text-4xl font-black text-white tracking-tighter uppercase italic mb-4">The <span className="text-gold">Syllabus.</span></h3>
                    <p className="text-slate-400 font-bold italic mb-12">Submit your node identity to secure the curriculum roadmap and lab schedules.</p>
                    <form className="space-y-6" onSubmit={(e) => e.preventDefault()}>
                        <input type="text" placeholder="Identity Name" className="w-full bg-white/5 border border-white/10 rounded-2xl p-6 text-white text-sm font-bold focus:outline-none focus:border-gold transition-all" />
                        <input type="email" placeholder="Access Email" className="w-full bg-white/5 border border-white/10 rounded-2xl p-6 text-white text-sm font-bold focus:outline-none focus:border-gold transition-all" />
                        <Button className="w-full py-10 bg-gold text-midnight font-black text-xl uppercase italic rounded-2xl shadow-gold hover:scale-[1.02] active:scale-95 transition-all">Submit & Access</Button>
                    </form>
                </motion.div>
            </div>
        )}
      </AnimatePresence>

      <style>{`
        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
        @keyframes spin {
            from { transform: rotateY(0deg); }
            to { transform: rotateY(360deg); }
        }
        .perspective-1000 {
            perspective: 1000px;
        }
        .truncate-3-lines {
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
      `}</style>

      {/* SEO Schema Injection */}
      <script type="application/ld+json">
        {JSON.stringify({
          "@context": "https://schema.org",
          "@type": "Course",
          "name": "Generative AI Masterclass",
          "description": "Architect high-performance AI systems with LLMs, RAG, and Agentic workflows.",
          "provider": { "@type": "Organization", "name": "OneBridge Infotech", "url": "https://onebridgeinfotech.com" },
          "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "ratingCount": "127" },
          "hasCourseInstance": [
            { "@type": "CourseInstance", "courseMode": "Online", "courseWorkload": "PT48H", "location": { "@type": "VirtualLocation", "url": "https://onebridgeinfotech.com/generative-ai-course" } }
          ]
        })}
      </script>
    </div>
  );
}
