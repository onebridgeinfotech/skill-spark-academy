const WordGlobe = () => {
    const locations = ["USA", "Canada", "Australia", "UAE", "UK", "Hyderabad", "Bangalore", "Chennai", "Pune", "Mumbai", "Delhi NCR", "London", "Dubai", "Singapore"];
    return (
        <div className="relative w-full h-[500px] flex items-center justify-center perspective-1000 overflow-hidden">
            <div className="absolute w-[300px] h-[300px] bg-gold/10 rounded-full blur-[80px] animate-pulse" />
            <div className="absolute w-[320px] h-[320px] border border-gold/10 rounded-full rotate-45" />
            <div className="absolute z-10 w-24 h-24 bg-midnight rounded-full flex items-center justify-center shadow-gold border border-gold/30">
                <MapPin className="h-10 w-10 text-gold animate-bounce" />
            </div>
            <div className="relative w-full h-full animate-[spin_60s_linear_infinite]">
                {locations.map((text, i) => {
                    const angle = (i / locations.length) * Math.PI * 2;
                    const radius = 170;
                    const x = Math.cos(angle) * radius;
                    const y = Math.sin(angle) * (radius * 0.4);
                    const z = Math.sin(angle) * radius;
                    return (
                        <motion.div key={i} className="absolute left-1/2 top-1/2" style={{ x, y }} animate={{ opacity: [0.3, 0.8, 0.3], scale: [0.8, 1.1, 0.8] }}>
                            <span className="whitespace-nowrap font-tech font-black text-[10px] md:text-sm uppercase tracking-tighter text-gold/40 hover:text-gold transition-colors">
                                {text}
                            </span>
                        </motion.div>
                    );
                })}
            </div>
        </div>
    );
};

function GenerativeAICourse() {
